<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Theme applied while the process is starting -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>

        <!-- Android 12+ Splash Screen API -->
        <item name="android:windowSplashScreenBackground">#1A73E8</item>
    </style>

    <!-- Theme applied after Flutter initializes -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/splash_gradient</item>
    </style>
</resources>
