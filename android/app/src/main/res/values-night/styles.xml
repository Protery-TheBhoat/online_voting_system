<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied while the process is starting (Dark Mode) -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>

        <!-- Android 12+ Splash Screen API -->
        <item name="android:windowSplashScreenAnimatedIcon" xmlns:android="http://schemas.android.com/apk/res/android">@drawable/ic_ballot_box</item>
        <item name="android:windowSplashScreenBackground" xmlns:android="http://schemas.android.com/apk/res/android">@color/splash_color</item>
    </style>

    <!-- Theme applied after Flutter initializes (Dark Mode) -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <!-- Match background to avoid flash during transition -->
        <item name="android:windowBackground">@drawable/splash_gradient</item>
    </style>
</resources>
